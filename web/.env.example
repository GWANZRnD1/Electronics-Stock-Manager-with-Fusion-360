# Environment template for the web app.
# Copy this to `.env.local` and fill in values:  cp .env.example .env.local
# `.env.local` is git-ignored and is what Next.js (next dev/build) and
# drizzle-kit (db:push/generate/migrate) load. Only DATABASE_URL is required.

# ── Required ────────────────────────────────────────────────────────────────

# Postgres connection string. The DB client sets `prepare: false`, so a Neon /
# Supabase POOLED connection string works (use the host containing "-pooler").
# Local Postgres example:
#   postgresql://postgres:postgres@localhost:5432/ecstock
DATABASE_URL=

# ── Optional: access gate ───────────────────────────────────────────────────

# Shared PIN that guards the whole app (cookie set on /unlock). Leave blank to
# DISABLE the gate — convenient for local dev.
ACCESS_PIN=

# ── Optional: distributor lookups (auto-fill MPN on add/receive) ─────────────
# Without these, /api/parts/lookup returns mock offers instead of live data.

# DigiKey Product Information V4 (OAuth2 client_credentials).
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
# Defaults to DigiKey's sandbox. Set to "false" to hit the production API.
DIGIKEY_USE_SANDBOX=

# Mouser Search API key.
MOUSER_API_KEY=

# ── Optional: machine-to-machine endpoints ───────────────────────────────────

# Bearer token the Fusion 360 add-in sends to POST /api/fusion/{library,bom}.
# Leave blank to leave those endpoints open (dev only).
FUSION_API_TOKEN=

# Bearer token for the GET /api/cron/keepalive endpoint (Vercel Cron sends
# `Authorization: Bearer <CRON_SECRET>`). Leave blank to leave it open.
CRON_SECRET=
